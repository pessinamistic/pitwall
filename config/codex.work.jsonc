{
  // WORK MACHINE TEMPLATE — generator input for scripts/sync-codex-agents.mjs;
  // Codex never reads this file. Every "TODO" must be replaced with a model
  // slug verified ON THE WORK ACCOUNT before generating with --profile work.
  //
  // To find valid slugs there: run codex once, then read
  // ~/.codex/models_cache.json (the "slug" fields with visibility "list"),
  // or open the /model picker in the TUI. Do NOT paste display names —
  // "GPT-5.6-Terra" is a display name; the slug is "gpt-5.6-terra". The
  // documented flagship is gpt-5.6-sol if that workspace exposes it.
  //
  // Reasoning efforts are real values, kept from the tier intent — only the
  // model slugs need filling. validate.mjs warns (not fails) on TODOs here.
  "agent": {
    "tech-lead":     { "model": "TODO", "model_reasoning_effort": "high" },   // strongest available
    "senior-dev":    { "model": "TODO", "model_reasoning_effort": "high" },   // strongest available
    "implementer":   { "model": "TODO", "model_reasoning_effort": "medium" }, // balanced mid
    "boilerplate":   { "model": "TODO", "model_reasoning_effort": "low" },    // cheapest available
    "code-reviewer": { "model": "TODO", "model_reasoning_effort": "high",     // mid + high reasoning
                       "sandbox_mode": "read-only" },                         // reviewer must not edit
    "debugger":      { "model": "TODO", "model_reasoning_effort": "high" }    // mid + high reasoning
  }
}
