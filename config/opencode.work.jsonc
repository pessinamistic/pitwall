{
  "$schema": "https://opencode.ai/config.json",

  // WORK MACHINE TEMPLATE — every "TODO" below must be replaced before this
  // profile is usable. On the work machine, run:
  //
  //   opencode models | grep -i copilot
  //
  // and paste the verbatim IDs from that output into docs/model-routing.md
  // and into the slots below. Copilot's marketing names ("Claude Sonnet
  // 4.6", "GPT-5.4", etc.) are NOT OpenCode model IDs — guessing them
  // produces a config that fails at invocation time with an unhelpful
  // error. Only strings copied verbatim from `opencode models` are valid.
  //
  // Tier intent per role — see docs/model-routing.md. Fill each TODO with a model
  // that satisfies the tier comment on its line, not just any Copilot ID.
  "model": "github-copilot/claude-sonnet-5", // strongest available — same model as tech-lead below

  "permission": {
    "skill": { "*": "allow" }
  },

  "agent": {
    "tech-lead":     { "model": "github-copilot/claude-sonnet-5" }, // strongest available
    "senior-dev":    { "model": "github-copilot/claude-sonnet-4.6" }, // strong mid
    "implementer":   { "model": "github-copilot/claude-sonnet-4.5" }, // code-tuned mid
    "boilerplate":   { "model": "github-copilot/claude-haiku-4.5" }, // cheapest available
    "code-reviewer": { "model": "github-copilot/gpt-5.6-terra" }, // reasoning-tuned
    "debugger":      { "model": "github-copilot/gpt-5.6-terra" }, // reasoning-tuned

    // Built-in — keep cheap so it doesn't compete with tech-lead.
    "plan": { "model": "github-copilot/claude-haiku-4.5" }, // cheapest available

    // Fleet mode's opencode backend launches `opencode run --agent
    // fleet-<role>`, a distinct agent identifier from the bare role name
    // above (see docs/fleet-mode.md and scripts/sync-fleet-agents.mjs) —
    // OpenCode's agent.<name>.model config is keyed by the exact invoked
    // identifier, confirmed empirically to NOT fall back to a same-named
    // entry under a different key, so each fleet-<role> needs its own
    // entry here. Every value below is a deliberate 1:1 mirror of its
    // non-fleet counterpart above — keep them in sync if you change one.
    "fleet-tech-lead":     { "model": "github-copilot/claude-sonnet-5" },
    "fleet-senior-dev":    { "model": "github-copilot/claude-sonnet-4.6" },
    "fleet-implementer":   { "model": "github-copilot/claude-sonnet-4.5" },
    "fleet-boilerplate":   { "model": "github-copilot/claude-haiku-4.5" },
    "fleet-code-reviewer": { "model": "github-copilot/gpt-5.6-terra" },
    "fleet-debugger":      { "model": "github-copilot/gpt-5.6-terra" }
  }
}
