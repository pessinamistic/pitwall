{
  "$schema": "https://opencode.ai/config.json",

  // Tier intent per role — see docs/model-routing.md. If you change a model here,
  // check it still satisfies the intent comment on its line.
  "model": "github-copilot/claude-sonnet-5",

  "permission": {
    "skill": { "*": "allow" }
  },

  "agent": {
    "tech-lead":     { "model": "github-copilot/claude-sonnet-5" }, // strongest available
    "senior-dev":    { "model": "github-copilot/claude-sonnet-5" }, // strong mid
    "implementer":   { "model": "github-copilot/claude-sonnet-4.6" }, // code-tuned mid
    "boilerplate":   { "model": "github-copilot/claude-haiku-4.5" }, // cheapest available
    "code-reviewer": { "model": "github-copilot/gpt-5.6-terra" }, // reasoning-tuned
    "debugger":      { "model": "github-copilot/gpt-5.6-terra" }, // reasoning-tuned

    // Built-in — keep cheap so it doesn't compete with tech-lead.
    "plan": { "model": "github-copilot/claude-haiku-4.5" } // cheapest available
  }

  // senior-dev, code-reviewer, and debugger all route to the remote Ollama
  // host referenced above. If that host is unreachable, those three roles
  // fail together. Local-only fallback for all three (code-reviewer
  // included): swap their model to ollama-local/deepseek-coder-v2:16b,
  // the largest model available on the local-only Ollama instance.
}
